---
const { label = 'Comparison', title, subtitle, source, leftLabel = '', rightLabel = '', rows = [] } = Astro.props;
const W = 800, headerH = 56, rowH = 64, padX = 32;
const colW = (W - padX * 2) / 2;
const H = headerH + rows.length * rowH + 20;
---
<figure class="exhibit">
  <div class="exhibit-frame">
    <div class="exhibit-label">{label}</div>
    {title && <div class="exhibit-title">{title}</div>}
    {subtitle && <div class="exhibit-subtitle">{subtitle}</div>}
    <div class="exhibit-svg-wrapper">
      <svg viewBox={`0 0 ${W} ${H}`} xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
        <line x1={W / 2} y1={20} x2={W / 2} y2={H - 20} stroke="#C8C2B5" stroke-width="0.5"/>
        <line x1={padX} y1={headerH} x2={W - padX} y2={headerH} stroke="#1A1A1A" stroke-width="0.8"/>
        <text x={padX + colW / 2} y={headerH - 18} text-anchor="middle" font-family="'IBM Plex Sans', sans-serif" font-size="11" fill="#7A1F1F" font-weight="600" letter-spacing="0.16em" text-transform="uppercase">{leftLabel}</text>
        <text x={padX + colW + colW / 2} y={headerH - 18} text-anchor="middle" font-family="'IBM Plex Sans', sans-serif" font-size="11" fill="#7A1F1F" font-weight="600" letter-spacing="0.16em">{rightLabel}</text>
        {rows.map((r, ri) => {
          const y = headerH + ri * rowH;
          return (
            <g>
              <foreignObject x={padX + 10} y={y + 12} width={colW - 20} height={rowH - 14}>
                <div xmlns="http://www.w3.org/1999/xhtml" style="font-family: 'Spectral', serif; font-size: 14px; line-height: 1.5; color: #1A1A1A;">{r.left}</div>
              </foreignObject>
              <foreignObject x={padX + colW + 10} y={y + 12} width={colW - 20} height={rowH - 14}>
                <div xmlns="http://www.w3.org/1999/xhtml" style="font-family: 'Spectral', serif; font-size: 14px; line-height: 1.5; color: #1A1A1A;">{r.right}</div>
              </foreignObject>
              {ri < rows.length - 1 && <line x1={padX} y1={y + rowH} x2={W - padX} y2={y + rowH} stroke="#C8C2B5" stroke-width="0.4"/>}
            </g>
          );
        })}
      </svg>
    </div>
    {source && <div class="exhibit-source" set:html={`<strong>Source.</strong> ${source}`} />}
  </div>
</figure>
