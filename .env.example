# Glossa — variables de entorno (SOLO NOMBRES, nunca valores)
# Los valores viven en 1Password (bóveda `ademas.ai`) y se leen con `op` en tiempo de ejecución.
# Ver docs/10-Modelos-y-Credenciales.md y CLAUDE.md. NUNCA pegar secretos aquí ni en git.
#
# Patrón de lectura (no imprime el valor):
#   export OPENROUTER_API_KEY=$(op item get "OpenRouter - API Key" --vault ademas.ai --fields credential --reveal)

# --- Base de datos / KB (phd-kb, Supabase wtwuvrtmadnlezkbesqp) ---
SUPABASE_URL=                 # op item: "Supabase thesis" (campo url)
SUPABASE_SERVICE_KEY=         # op item: "Supabase thesis" / "Supabase PAT — ademas-ai-cli" — escribe glossa_*, lee evaluated_items
# Alternativa Postgres directa (pgvector): op item "Radius - Neon DATABASE_URL"

# --- Modelos ---
OPENROUTER_API_KEY=           # op item: "OpenRouter - API Key" — zoo de modelos baratos (carga)
ANTHROPIC_API_KEY=            # op item: "Anthropic" — Opus directo (análisis/redacción final, Citations)
OPENAI_API_KEY=               # op item: "Radius - OpenAI API Key" — embeddings del KB (dedicado, fijo)

# --- Buscadores de agente ---
TAVILY_API_KEY=               # op item: "Tavily" — buscador semántico (fallback documentado de Exa; en uso)
PERPLEXITY_API_KEY=           # op item: "Perplexity" — alternativa
# EXA_API_KEY=                # ⛳ PENDIENTE: Exa es el buscador decidido (doc 04) pero NO está en la bóveda todavía.
#                               Hasta tenerlo, el router usa Tavily/Perplexity + KB-first + OpenAlex.

# --- Fuentes abiertas (sin key) ---
OPENALEX_MAILTO=              # email para el "polite pool" de OpenAlex (api.openalex.org) — sin key
# Otras disponibles en bóveda si se necesitan: CourtListener, SemanticScholar, CORE, Firecrawl

# --- Publicación (GitHub / Vercel) ---
# GitHub: usar `gh` autenticado (cuenta aauml) en Code/Cowork; en chat/móvil, op item "GitHub" / LECTURAS_PAT.
# Vercel: despliega solo en cada push a main de aauml/glossa (no requiere key local).
